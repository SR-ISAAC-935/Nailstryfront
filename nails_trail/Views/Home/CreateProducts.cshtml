@{
}

<form id="productForm" enctype="multipart/form-data" class="row g-3">

    <div class="col-md-6">
        <label class="form-label">Nombre del producto</label>
        <input type="text" id="product_name" class="form-control" />
    </div>

    <div class="col-md-6">
        <label class="form-label">Imagen</label>
        <input type="file" id="product_url_image" class="form-control" accept=".jpg,.jpeg,.png,image/jpeg" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Categoría</label>
        <input type="number" id="id_category" class="form-control" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Precio Venta</label>
        <input type="number" id="sells_at" class="form-control" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Precio Compra</label>
        <input type="number" id="buyed_at" class="form-control" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Stock</label>
        <input type="number" id="stock" class="form-control" />
    </div>

    <div class="col-12 mt-3">
        <button type="button" id="AddTable" class="btn btn-secondary">
            Agregar
        </button>

        <button type="button" id="Submit" class="btn btn-primary">
            Enviar
        </button>
    </div>

</form>
<table class="table" id="product_table">
    <thead>
        <tr>
            <th>Product Name</th>
            <th>Product Image</th>
            <th>Category ID</th>
            <th>stock</th>
            <th>buyed at</th>
            <th>sells at</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    </tbody>
</table>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/product.js" asp-append-version="true"></script>
}