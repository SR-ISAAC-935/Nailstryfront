@{
}
<form id="ServicesForm" enctype="multipart/form-data" class="row g-3">

    <div class="col-md-6">
        <label class="form-label">Nombre del Servicio</label>
        <input type="text" id="ServicesName" class="form-control" />
    </div>

    <div class="col-md-6">
        <label class="form-label">Imagen</label>
        <input type="file" id="ServicesUrlImage" class="form-control" accept=".jpg,.jpeg,.png,image/jpeg" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Categoría</label>
        <input type="number" id="IdCategory" class="form-control" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Precio Servicio</label>
        <input type="number" id="prices" class="form-control" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Tiempo Servicio</label>
        <input type="time" id="duration" class="form-control" />
    </div>

    <div class="col-12 mt-3">
        <button type="button" id="AddTable" class="btn btn-secondary">
            Agregar
        </button>

        <button type="button" id="Submit" class="btn btn-primary">
            Enviar
        </button>
    </div>

</form>
<table class="table" id="product_table">
    <thead>
        <tr>
            <th>services Name</th>
            <th>service Image</th>
            <th>Category ID</th>
            <th>sells at</th>
            <th>duration</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    </tbody>
</table>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Services.js" asp-append-version="true"></script>
}